# Tripwire environment — never commit real values (TOOLS.md).
# All M1 tests and builds run WITHOUT any of these set: the LLM layer falls back to the
# deterministic mock batch client and no external calls are made.

# Postgres + pgvector (just db-up provides a local one)
DATABASE_URL=postgres://tripwire:tripwire@localhost:5432/tripwire

# Anthropic Batches API — Haiku triage + Sonnet synthesis (M2+; mock used when absent)
ANTHROPIC_API_KEY=

# News/funding search (M2+)
EXA_API_KEY=

# Scrape fallback, only after raw HTTP fails twice (M2+)
FIRECRAWL_API_KEY=

# SEC EDGAR fair-access UA string with contact email (M2+)
SEC_EDGAR_USER_AGENT=

# HubSpot public app OAuth (M2)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Slack alerts + interactive feedback (M2)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Inngest scheduling, production only (M2)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Encrypts stored HubSpot/Slack OAuth tokens at rest (M2)
TOKEN_ENCRYPTION_KEY=

# Metered billing (M3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OPTIONAL — without this, exec-change trigger profiles stay disabled (product invariant 4)
PEOPLE_DATA_API_KEY=
