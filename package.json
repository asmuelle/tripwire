{
  "name": "tripwire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @tripwire/web dev",
    "test": "vitest run",
    "e2e": "echo 'e2e: no Playwright suite yet — surfaces land with M2 (see DESIGN.md). Nothing to run.'",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "migrate": "pnpm --filter @tripwire/db migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.4"
  }
}
